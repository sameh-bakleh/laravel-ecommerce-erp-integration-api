APP_NAME="Laravel ERP Integration API"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Europe/Berlin
APP_URL=http://localhost:8000

APP_LOCALE=de
APP_FALLBACK_LOCALE=en

LOG_CHANNEL=stack
LOG_LEVEL=debug

# --- Database ---
# MySQL (default for Docker Compose)
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=erp_integration
DB_USERNAME=root
DB_PASSWORD=

# PostgreSQL (supported; use docker compose --profile postgres)
# DB_CONNECTION=pgsql
# DB_HOST=127.0.0.1
# DB_PORT=5432
# DB_DATABASE=erp_integration
# DB_USERNAME=erp
# DB_PASSWORD=erp

# SQLite (fastest local / PHPUnit default)
# DB_CONNECTION=sqlite
# DB_DATABASE=database/database.sqlite

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database
SESSION_DRIVER=array

# Optional Redis queue profile (production throughput)
# QUEUE_CONNECTION=redis
# REDIS_CLIENT=phpredis
# REDIS_HOST=127.0.0.1
# REDIS_PASSWORD=null
# REDIS_PORT=6379

MAIL_MAILER=log

# --- Integration (sample values only — replace in your deployment) ---
INTEGRATION_API_TOKEN=change-me-in-production
ERP_WEBHOOK_SECRET=change-me-webhook-hmac
ERP_SIMULATE_TRANSPORT_FAILURE=false

# Optional future HTTP ERP client (never commit real tenant URLs or OAuth secrets)
# ERP_BASE_URL=https://sandbox.example.invalid/
